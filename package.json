{
  "name": "agentmcplab",
  "version": "0.1.0",
  "private": true,
  "description": "AgentMcpLab — self-hosted bot / browser-automation detection lab",
  "type": "module",
  "workspaces": ["client", "bench"],
  "scripts": {
    "dev": "npm --workspace client run dev",
    "build": "npm --workspace client run build",
    "preview": "wrangler pages dev client/dist --compatibility-date=2024-09-01",
    "deploy": "npm run build && wrangler pages deploy client/dist",
    "db:init": "wrangler d1 execute agentmcplab --local --file=./schema.sql",
    "db:init:remote": "wrangler d1 execute agentmcplab --remote --file=./schema.sql",
    "typecheck": "tsc -p tsconfig.json --noEmit && tsc -p client/tsconfig.json --noEmit",
    "lint": "biome lint .",
    "format": "biome format --write .",
    "check": "biome check --write .",
    "bench": "npm --workspace bench run bench"
  },
  "dependencies": {
    "hono": "^4.6.3"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@cloudflare/workers-types": "^4.20240925.0",
    "typescript": "^5.6.2",
    "wrangler": "^3.78.0"
  }
}
